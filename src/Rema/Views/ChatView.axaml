<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Rema.ViewModels"
             xmlns:sc="using:StrataTheme.Controls"
             x:Class="Rema.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             FontSize="{Binding ChatFontSize}">

  <UserControl.Styles>
    <Style Selector="Button.suggestion-chip">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface2}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.suggestion-chip:pointerover">
      <Setter Property="Background" Value="{DynamicResource Brush.ControlHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentSubtle}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>
  </UserControl.Styles>

  <!-- Transcript item data templates -->
  <UserControl.DataTemplates>

    <!-- ═══ User Message ═══ -->
    <DataTemplate DataType="vm:UserMessageItem">
      <sc:StrataChatMessage Role="User" HorizontalAlignment="Right" MaxWidth="560"
                            Author="{Binding Author}"
                            Timestamp="{Binding TimestampText}"
                            IsEditable="True"
                            IsEditing="{Binding IsEditing, Mode=TwoWay}"
                            EditText="{Binding EditText, Mode=TwoWay}"
                            EditConfirmedCommand="{Binding ConfirmEditCommand}"
                            ApplyEditToContent="False">
        <sc:StrataChatMessage.Content>
          <SelectableTextBlock Text="{Binding Content}" TextWrapping="Wrap" />
        </sc:StrataChatMessage.Content>
      </sc:StrataChatMessage>
    </DataTemplate>

    <!-- ═══ Assistant Message ═══ -->
    <DataTemplate DataType="vm:AssistantMessageItem">
      <sc:StrataChatMessage Role="Assistant" HorizontalAlignment="Left" MaxWidth="760"
                            IsStreaming="{Binding IsStreaming}"
                            Author="{Binding Author}"
                            Timestamp="{Binding TimestampText}">
        <sc:StrataChatMessage.Content>
          <sc:StrataMarkdown Markdown="{Binding Content}" IsInline="True" />
        </sc:StrataChatMessage.Content>
      </sc:StrataChatMessage>
    </DataTemplate>

    <!-- ═══ Error Message ═══ -->
    <DataTemplate DataType="vm:ErrorMessageItem">
      <Border Background="#30FF4444" CornerRadius="8" Padding="14,10" Margin="0,4">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                     Foreground="#FFFF6666" FontSize="13" />
          <Button Content="↻ Retry"
                  IsVisible="{Binding RetryCommand, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Command="{Binding RetryCommand}"
                  Classes="subtle"
                  Padding="10,4" MinHeight="0" FontSize="12"
                  Foreground="#FFFF6666"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- ═══ Reasoning Block ═══ -->
    <DataTemplate DataType="vm:ReasoningItem">
      <sc:StrataThink Label="Reasoning"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}">
        <sc:StrataThink.Content>
          <sc:StrataMarkdown Markdown="{Binding Content}" IsInline="True" />
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ═══ Tool Group (multiple tools) ═══ -->
    <DataTemplate DataType="vm:ToolGroupItem">
      <sc:StrataThink Label="{Binding Label}"
                      Meta="{Binding Meta}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}"
                      ProgressValue="{Binding ProgressValue}">
        <sc:StrataThink.Content>
          <ItemsControl ItemsSource="{Binding ToolCalls}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:ToolCallItem">
                <sc:StrataAiToolCall ToolName="{Binding ToolName}"
                                     Status="{Binding Status}"
                                     DurationMs="{Binding DurationMs}"
                                     IsExpanded="{Binding IsExpanded}"
                                     InputParameters="{Binding InputParameters}"
                                     MoreInfo="{Binding MoreInfo}"
                                     MaxWidth="420" Margin="0,0,6,6" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ═══ Single Tool (standalone) ═══ -->
    <DataTemplate DataType="vm:SingleToolItem">
      <sc:StrataThink Label="{Binding Label}"
                      Meta="{Binding Meta}"
                      IsActive="{Binding IsActive}">
        <sc:StrataThink.Content>
          <sc:StrataAiToolCall ToolName="{Binding Label}"
                               Status="{Binding Status}"
                               IsExpanded="{Binding IsExpanded}"
                               InputParameters="{Binding InputParameters}"
                               MoreInfo="{Binding MoreInfo}"
                               MaxWidth="420" />
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ═══ Typing Indicator ═══ -->
    <DataTemplate DataType="vm:TypingIndicatorItem">
      <sc:StrataTypingIndicator Label="{Binding Label}"
                                IsActive="{Binding IsActive}" />
    </DataTemplate>

    <!-- ═══ Turn Model Label ═══ -->
    <DataTemplate DataType="vm:TurnModelItem">
      <TextBlock Text="{Binding ModelName}" FontSize="10" Opacity="0.4"
                 Foreground="{DynamicResource Brush.TextTertiary}"
                 Margin="0,2,0,0" />
    </DataTemplate>

    <!-- ═══ Terminal Preview ═══ -->
    <DataTemplate DataType="vm:TerminalPreviewItem">
      <StackPanel Spacing="4">
        <sc:StrataAiToolCall ToolName="{Binding ToolName}"
                             Status="{Binding Status}"
                             DurationMs="{Binding DurationMs}"
                             IsExpanded="{Binding IsExpanded}"
                             MaxWidth="420" />
        <Border Background="{DynamicResource Brush.Surface1}" CornerRadius="6" Padding="10,8" Margin="0,0,0,4"
                IsVisible="{Binding IsExpanded}">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding Command}" FontFamily="Cascadia Code,Consolas,monospace"
                       FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Output}" FontFamily="Cascadia Code,Consolas,monospace"
                       FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}" TextWrapping="Wrap"
                       IsVisible="{Binding Output, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       MaxLines="20" />
          </StackPanel>
        </Border>
      </StackPanel>
    </DataTemplate>

    <!-- ═══ Sub-agent ═══ -->
    <DataTemplate DataType="vm:SubagentToolCallItem">
      <sc:StrataThink Label="{Binding Title}"
                      Meta="{Binding Meta}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}"
                      ProgressValue="{Binding ProgressValue}">
        <sc:StrataThink.HeaderExtra>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border IsVisible="{Binding HasModeLabel}" CornerRadius="4" Padding="6,1"
                    Background="{DynamicResource Brush.AccentSubtle}">
              <TextBlock Text="{Binding ModeLabel}" FontSize="10"
                         Foreground="{DynamicResource Brush.AccentDefault}" />
            </Border>
            <TextBlock Text="{Binding DurationText}" FontSize="10"
                       Foreground="{DynamicResource Brush.TextTertiary}"
                       IsVisible="{Binding DurationText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          </StackPanel>
        </sc:StrataThink.HeaderExtra>
        <sc:StrataThink.Content>
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding ModelDisplayName}" FontSize="10"
                       Foreground="{DynamicResource Brush.TextTertiary}"
                       IsVisible="{Binding HasModelName}" Margin="0,0,0,4" />
            <ItemsControl ItemsSource="{Binding Activities}" IsVisible="{Binding HasActivities}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ToolCallItem">
                  <sc:StrataAiToolCall ToolName="{Binding ToolName}"
                                       Status="{Binding Status}"
                                       DurationMs="{Binding DurationMs}"
                                       IsExpanded="{Binding IsExpanded}"
                                       InputParameters="{Binding InputParameters}"
                                       MoreInfo="{Binding MoreInfo}"
                                       MaxWidth="420" Margin="0,0,6,6" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ═══ File Changes Summary ═══ -->
    <DataTemplate DataType="vm:FileChangesSummaryItem">
      <sc:StrataThink Label="{Binding Label}">
        <sc:StrataThink.HeaderExtra>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding TotalStatsAdded}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.SuccessDefault}" />
            <TextBlock Text="{Binding TotalStatsRemoved}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.DangerDefault}"
                       IsVisible="{Binding HasTotalRemovals}" />
          </StackPanel>
        </sc:StrataThink.HeaderExtra>
        <sc:StrataThink.Content>
          <ItemsControl ItemsSource="{Binding FileChanges}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="2" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:FileChangeItem">
                <Border Padding="6,4" CornerRadius="4">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding ActionIcon}" Margin="0,0,6,0"
                               FontSize="13" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center" Margin="8,0,0,0">
                      <TextBlock Text="{Binding StatsAdded}" FontSize="11" FontWeight="Medium"
                                 Foreground="{DynamicResource Brush.SuccessDefault}" />
                      <TextBlock Text="{Binding StatsRemoved}" FontSize="11" FontWeight="Medium"
                                 Foreground="{DynamicResource Brush.DangerDefault}"
                                 IsVisible="{Binding HasRemovals}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Directory}" FontSize="11"
                                 Foreground="{DynamicResource Brush.TextTertiary}"
                                 TextTrimming="CharacterEllipsis"
                                 IsVisible="{Binding Directory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ═══ Question Card ═══ -->
    <DataTemplate DataType="vm:QuestionItem">
      <sc:StrataQuestionCard Question="{Binding Question}"
                             OptionsList="{Binding OptionsList}"
                             AllowFreeText="{Binding AllowFreeText}"
                             SelectedAnswer="{Binding SelectedAnswer, Mode=TwoWay}"
                             IsAnswered="{Binding IsAnswered, Mode=TwoWay}" />
    </DataTemplate>

    <!-- ═══ File Attachment ═══ -->
    <DataTemplate DataType="vm:FileAttachmentItem">
      <Button Classes="subtle" Command="{Binding OpenFileCommand}" Padding="8,6" Cursor="Hand">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="📎" FontSize="14" VerticalAlignment="Center" />
          <TextBlock Text="{Binding FileName}" FontSize="12"
                     Foreground="{DynamicResource Brush.AccentDefault}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </DataTemplate>

    <!-- ═══ Source Citations ═══ -->
    <DataTemplate DataType="vm:SourcesListItem">
      <sc:StrataThink Label="Sources" IsExpanded="{Binding IsExpanded}">
        <sc:StrataThink.Content>
          <ItemsControl ItemsSource="{Binding Sources}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="2" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:SourceItem">
                <Button Classes="subtle" Command="{Binding OpenCommand}" Padding="4,3" Cursor="Hand">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🔗" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Title}" FontSize="11"
                               Foreground="{DynamicResource Brush.AccentDefault}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="300" />
                    <TextBlock Text="{Binding Domain}" FontSize="10"
                               Foreground="{DynamicResource Brush.TextTertiary}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

  </UserControl.DataTemplates>

  <!-- ═══ Main Layout ═══ -->
  <sc:StrataChatShell x:Name="ChatShell" IsStreaming="{Binding IsBusy}"
                      PresenceText="{Binding GitStatusText}">

    <!-- Git status header -->
    <sc:StrataChatShell.Header>
      <DockPanel IsVisible="{Binding HasGitInfo}" LastChildFill="False">
        <!-- Branch name -->
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Text="⎇" FontSize="12" Foreground="{DynamicResource Brush.TextTertiary}"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding GitBranch}" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.TextPrimary}" VerticalAlignment="Center" />
          <Border CornerRadius="4" Padding="6,1"
                  Background="{DynamicResource Brush.Surface2}">
            <TextBlock Text="{Binding GitModeText}" FontSize="10"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
          </Border>
        </StackPanel>

        <!-- Refresh button -->
        <Button DockPanel.Dock="Right" Classes="subtle" Padding="4"
                Command="{Binding RefreshGitStatusCommand}"
                ToolTip.Tip="Refresh git status" Cursor="Hand">
          <TextBlock Text="↻" FontSize="14" Foreground="{DynamicResource Brush.TextTertiary}" />
        </Button>
      </DockPanel>
    </sc:StrataChatShell.Header>

    <!-- Transcript -->
    <sc:StrataChatShell.Transcript>
      <Panel>
        <!-- Search overlay (Ctrl+F) -->
        <Border IsVisible="{Binding IsSearchOpen}" ZIndex="10"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="16,8" Padding="8,6" CornerRadius="8"
                Background="{DynamicResource Brush.Surface2}"
                BoxShadow="0 2 8 0 #40000000">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Text="{Binding SearchQuery, Mode=TwoWay}"
                     PlaceholderText="Search…" Width="200" FontSize="12"
                     x:Name="SearchBox" />
            <TextBlock Text="{Binding SearchResultText}" FontSize="11"
                       Foreground="{DynamicResource Brush.TextTertiary}"
                       VerticalAlignment="Center" MinWidth="60" />
            <Button Classes="subtle" Command="{Binding ToggleSearchCommand}"
                    Padding="4" ToolTip.Tip="Close">
              <TextBlock Text="✕" FontSize="12" />
            </Button>
          </StackPanel>
        </Border>

        <!-- Welcome panel (shown when no chat active) -->
        <StackPanel x:Name="WelcomePanel" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Spacing="16"
                    IsVisible="{Binding CurrentChat, Converter={x:Static ObjectConverters.IsNull}}">
          <TextBlock Text="🔄" FontSize="40" HorizontalAlignment="Center" Opacity="0.4" />
          <TextBlock Text="Ask Rema about deployments, pipelines, or shift status."
                     FontSize="14" Opacity="0.5" TextAlignment="Center" MaxWidth="340"
                     Foreground="{DynamicResource Brush.TextSecondary}" />
          <!-- Suggestion chips -->
          <ItemsControl ItemsSource="{Binding SuggestionChips}" Margin="0,4,0,0">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel HorizontalAlignment="Center" ItemWidth="NaN" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="suggestion-chip"
                        Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SelectSuggestionCommand}"
                        CommandParameter="{Binding}"
                        Margin="4,4">
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" MaxWidth="260" TextAlignment="Center" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Transcript items -->
        <ItemsControl x:Name="TranscriptList"
                      ItemsSource="{Binding MountedTranscriptTurns}"
                      Margin="24,20,24,20">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="12" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:TranscriptTurn">
              <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Spacing="8" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Panel>
    </sc:StrataChatShell.Transcript>

    <!-- Composer -->
    <sc:StrataChatShell.Composer>
      <StackPanel>
        <!-- Token usage badge -->
        <Border IsVisible="{Binding HasTokenUsage}"
                Padding="8,2" CornerRadius="8" Margin="0,0,0,4"
                Background="{DynamicResource Brush.Surface2}"
                Opacity="0.7" HorizontalAlignment="Right">
          <ToolTip.Tip>
            <StackPanel Spacing="6" MinWidth="180">
              <TextBlock Text="Token Usage" FontWeight="SemiBold" FontSize="12"
                         Foreground="{DynamicResource Brush.TextPrimary}" />
              <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="0,2,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Input" FontSize="11"
                           Foreground="{DynamicResource Brush.TextSecondary}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TokenInputDisplay}" FontSize="11"
                           Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Right" Margin="16,0,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Output" FontSize="11" Margin="0,4,0,0"
                           Foreground="{DynamicResource Brush.TextSecondary}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TokenOutputDisplay}" FontSize="11" Margin="16,4,0,0"
                           Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Right" />
              </Grid>
              <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Total" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextPrimary}" />
                <TextBlock Grid.Column="1" Text="{Binding TokenTotalDisplay}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.AccentDefault}" HorizontalAlignment="Right" Margin="16,0,0,0" />
              </Grid>
              <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}"
                      IsVisible="{Binding HasContextUsage}" />
              <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasContextUsage}">
                <TextBlock Grid.Column="0" Text="Context window" FontSize="11"
                           Foreground="{DynamicResource Brush.TextSecondary}" />
                <TextBlock Grid.Column="1" Text="{Binding ContextUsageDisplay}" FontSize="11"
                           Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Right" Margin="16,0,0,0" />
              </Grid>
            </StackPanel>
          </ToolTip.Tip>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="⚡" FontSize="10" VerticalAlignment="Center" />
            <TextBlock Text="{Binding TokenUsageSummary}" FontSize="10.5"
                       Foreground="{DynamicResource Brush.TextTertiary}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding TokenUsageSuffixText}" FontSize="10.5"
                       Foreground="{DynamicResource Brush.TextTertiary}" Opacity="0.7" VerticalAlignment="Center" />
          </StackPanel>
        </Border>
        <sc:StrataChatComposer x:Name="Composer"
                               PromptText="{Binding PromptText, Mode=TwoWay}"
                               IsBusy="{Binding IsBusy}"
                               Placeholder="Ask Rema…"
                               CanAttach="False"
                               Models="{Binding AvailableModels}"
                               SelectedModel="{Binding SelectedModel, Mode=TwoWay}"
                               IsRecording="{Binding IsRecording}"
                               VoiceCommand="{Binding ToggleVoiceCommand}"
                               SuggestionA="{Binding SuggestionA}"
                               SuggestionB="{Binding SuggestionB}"
                               SuggestionC="{Binding SuggestionC}"
                               IsSuggestionsGenerating="{Binding IsSuggestionsGenerating}" />
      </StackPanel>
    </sc:StrataChatShell.Composer>

  </sc:StrataChatShell>
</UserControl>
