<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:Rema.Localization"
             x:Class="Rema.Views.ChatView">

  <Grid RowDefinitions="*,Auto">
    <!-- Chat transcript area -->
    <ScrollViewer Grid.Row="0" Padding="32">
      <StackPanel Spacing="8">
        <TextBlock Text="{loc:Str Nav_Chat}" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource Brush.TextPrimary}"
                   Margin="0,0,0,16" />
        <TextBlock Text="{loc:Str Chat_Placeholder}" Opacity="0.5"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource Brush.TextSecondary}" />
      </StackPanel>
    </ScrollViewer>

    <!-- Composer -->
    <Border Grid.Row="1" Padding="16,8"
            Background="{DynamicResource Brush.Surface1}"
            BorderBrush="{DynamicResource Brush.BorderSubtle}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 PlaceholderText="{loc:Str Chat_Placeholder}"
                 Name="ComposerTextBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MaxHeight="120" />
        <Button Grid.Column="1" Classes="accent" Content="{loc:Str Chat_Send}"
                Margin="8,0,0,0" VerticalAlignment="Bottom"
                Padding="16,8" />
      </Grid>
    </Border>
  </Grid>

</UserControl>
