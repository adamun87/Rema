<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Rema.ViewModels"
        xmlns:models="using:Rema.Models"
        xmlns:views="using:Rema.Views"
        xmlns:loc="using:Rema.Localization"
        x:Class="Rema.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Rema"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        Background="{DynamicResource Brush.Surface0}">

  <Grid ColumnDefinitions="220,*">

    <!-- ═══ Sidebar (matches Lumi layout: top section content + bottom nav pill) ═══ -->
    <Border Grid.Column="0"
            Background="{DynamicResource Brush.Surface0}"
            BorderBrush="{DynamicResource Brush.BorderSubtle}"
            BorderThickness="0,0,1,0"
            ClipToBounds="True">
      <DockPanel>

        <!-- ── Top: App title + connection status ── -->
        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,4">
          <TextBlock Text="Rema" FontSize="20" FontWeight="Bold"
                     Foreground="{DynamicResource Brush.TextPrimary}" />
          <TextBlock Text="{Binding ConnectionStatus}"
                     FontSize="11" Opacity="0.6"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     Margin="0,2,0,0" />
        </StackPanel>

        <!-- ── Bottom: Nav pill (horizontal, Lumi-style) ── -->
        <Border DockPanel.Dock="Bottom" Margin="14,4,14,12" ClipToBounds="False">
          <Border Classes="nav-pill"
                  BorderBrush="{DynamicResource Brush.BorderSubtle}"
                  Background="{DynamicResource Brush.Surface1}"
                  ClipToBounds="False">
            <WrapPanel x:Name="NavRow" Orientation="Horizontal" HorizontalAlignment="Center" MaxWidth="178">
              <Button x:Name="NavDashboard" Classes="nav-icon active" Click="NavButton_Click" Tag="0"
                       ToolTip.Tip="{loc:Str Nav_Dashboard}">
                <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavShift" Classes="nav-icon" Click="NavButton_Click" Tag="1"
                       ToolTip.Tip="{loc:Str Nav_ShiftManagement}">
                <TextBlock Text="🔄" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavChat" Classes="nav-icon" Click="NavButton_Click" Tag="2"
                       ToolTip.Tip="{loc:Str Nav_Chat}">
                <TextBlock Text="💬" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavProjects" Classes="nav-icon" Click="NavButton_Click" Tag="3"
                       ToolTip.Tip="{loc:Str Nav_ServiceProjects}">
                <TextBlock Text="📁" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavMemories" Classes="nav-icon" Click="NavButton_Click" Tag="4"
                       ToolTip.Tip="{loc:Str Nav_Memories}">
                <TextBlock Text="🧠" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavSkills" Classes="nav-icon" Click="NavButton_Click" Tag="5"
                       ToolTip.Tip="{loc:Str Nav_Skills}">
                <TextBlock Text="🧰" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavMcpServers" Classes="nav-icon" Click="NavButton_Click" Tag="6"
                       ToolTip.Tip="{loc:Str Nav_McpServers}">
                <TextBlock Text="🔌" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavTools" Classes="nav-icon" Click="NavButton_Click" Tag="7"
                       ToolTip.Tip="{loc:Str Nav_Tools}">
                <TextBlock Text="🛠" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavAgents" Classes="nav-icon" Click="NavButton_Click" Tag="8"
                       ToolTip.Tip="{loc:Str Nav_Agents}">
                <TextBlock Text="🤖" FontSize="14" VerticalAlignment="Center" />
              </Button>
              <Button x:Name="NavSettings" Classes="nav-icon" Click="NavButton_Click" Tag="9"
                       ToolTip.Tip="{loc:Str Nav_Settings}">
                <TextBlock Text="⚙️" FontSize="14" VerticalAlignment="Center" />
              </Button>
            </WrapPanel>
          </Border>
        </Border>

        <!-- ── Middle: Section-specific sidebar content ── -->
        <Panel>
          <!-- Sidebar: Dashboard (0) -->
          <Panel x:Name="Sidebar0">
            <TextBlock Text="{loc:Str Nav_Dashboard}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Margin="20,12,16,0" />
          </Panel>

          <!-- Sidebar: Shifts (1) -->
          <Panel x:Name="Sidebar1" IsVisible="False" DataContext="{Binding ShiftsVM}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top"
                         Text="{loc:Str Nav_ShiftManagement}" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.TextSecondary}"
                         Margin="20,12,16,6" />
              <!-- Active shift summary chip -->
              <Border DockPanel.Dock="Top"
                      IsVisible="{Binding HasActiveShift}"
                      Background="{DynamicResource Brush.SurfaceVariant}"
                      CornerRadius="8" Padding="12,8" Margin="12,0,12,4">
                <StackPanel Spacing="2">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="▶" Foreground="{DynamicResource Brush.Accent}" FontSize="11" />
                    <TextBlock Text="{Binding ActiveShift.Name}"
                               FontSize="12" FontWeight="Medium"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Brush.TextPrimary}" />
                  </StackPanel>
                  <TextBlock FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}">
                    <Run Text="{Binding ActiveTrackedItems.Count}" />
                    <Run Text=" tracked" />
                  </TextBlock>
                </StackPanel>
              </Border>
              <!-- Shift history list -->
              <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,4,8,8">
                <StackPanel Spacing="1">
                  <TextBlock Text="{loc:Str Shift_History}" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Brush.TextTertiary}"
                             Margin="6,4,6,4"
                             IsVisible="{Binding HasShiftHistory}" />
                  <ItemsControl ItemsSource="{Binding ShiftHistory}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:Shift">
                        <Border Background="Transparent" CornerRadius="6" Padding="10,6" Margin="0,1">
                          <StackPanel Spacing="1">
                            <TextBlock Text="{Binding Name}" FontSize="12"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="10" Foreground="{DynamicResource Brush.TextTertiary}">
                              <Run Text="{Binding StartedAt, StringFormat='{}{0:MMM d}'}" />
                            </TextBlock>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </DockPanel>
          </Panel>

          <!-- Sidebar: Chat (2) -->
          <Panel x:Name="Sidebar2" IsVisible="False" DataContext="{Binding ChatVM}">
            <DockPanel>
              <DockPanel DockPanel.Dock="Top" Margin="16,8,16,0">
                <Button DockPanel.Dock="Right" Classes="subtle" Padding="7,5" MinHeight="0"
                        CornerRadius="6"
                        Command="{Binding NewChatCommand}"
                        ToolTip.Tip="{loc:Str Chat_NewChat}">
                  <TextBlock Text="+" FontSize="16" FontWeight="Bold" />
                </Button>
                <TextBlock Text="{loc:Str Nav_Chat}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           VerticalAlignment="Center" Margin="6,0,0,0" />
              </DockPanel>
              <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,8,8,8">
                <ItemsControl ItemsSource="{Binding Chats}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Chat">
                      <Button Classes="subtle" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Padding="10,8" MinHeight="0" Margin="0,1"
                              CornerRadius="6"
                              Command="{Binding $parent[Panel].((vm:ChatViewModel)DataContext).SelectChatCommand}"
                              CommandParameter="{Binding}">
                        <StackPanel Spacing="1">
                          <TextBlock Text="{Binding Title}" FontSize="13"
                                     Foreground="{DynamicResource Brush.TextPrimary}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MMM d, HH:mm}'}" FontSize="11"
                                     Foreground="{DynamicResource Brush.TextTertiary}" />
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </Panel>

          <!-- Sidebar: Projects (3) — shows project list like Lumi -->
          <Panel x:Name="Sidebar3" IsVisible="False" DataContext="{Binding ServiceProjectsVM}">
            <DockPanel>
              <DockPanel DockPanel.Dock="Top" Margin="16,8,16,0">
                <Button DockPanel.Dock="Right" Classes="subtle" Padding="7,5" MinHeight="0"
                        CornerRadius="6"
                        Command="{Binding NewProjectCommand}"
                        ToolTip.Tip="{loc:Str Projects_New}">
                  <TextBlock Text="+" FontSize="16" FontWeight="Bold" />
                </Button>
                <TextBlock Text="{loc:Str Nav_ServiceProjects}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           VerticalAlignment="Center" Margin="6,0,0,0" />
              </DockPanel>
              <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,8,8,8">
                <ItemsControl ItemsSource="{Binding Projects}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Classes="subtle" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Padding="10,8" MinHeight="0" Margin="0,1"
                              CornerRadius="6"
                              Command="{Binding $parent[Panel].((vm:ServiceProjectsViewModel)DataContext).EditProjectCommand}"
                              CommandParameter="{Binding}">
                        <StackPanel Spacing="1">
                          <TextBlock Text="{Binding Name}" FontSize="13"
                                     Foreground="{DynamicResource Brush.TextPrimary}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding AdoProjectName}" FontSize="11"
                                     Foreground="{DynamicResource Brush.TextTertiary}"
                                     TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </Panel>

          <!-- Sidebar: Memories (4) -->
          <Panel x:Name="Sidebar4" IsVisible="False">
            <TextBlock Text="{loc:Str Nav_Memories}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Margin="20,12,16,0" />
          </Panel>

          <!-- Sidebar: Skills (5) -->
          <Panel x:Name="Sidebar5" IsVisible="False">
            <TextBlock Text="{loc:Str Nav_Skills}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Margin="20,12,16,0" />
          </Panel>

          <!-- Sidebar: MCP servers (6) -->
          <Panel x:Name="Sidebar6" IsVisible="False">
            <TextBlock Text="{loc:Str Nav_McpServers}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Margin="20,12,16,0" />
          </Panel>

          <!-- Sidebar: Tools (7) -->
          <Panel x:Name="Sidebar7" IsVisible="False">
            <TextBlock Text="{loc:Str Nav_Tools}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Margin="20,12,16,0" />
          </Panel>

          <!-- Sidebar: Agents (8) -->
          <Panel x:Name="Sidebar8" IsVisible="False">
            <TextBlock Text="{loc:Str Nav_Agents}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Margin="20,12,16,0" />
          </Panel>

          <!-- Sidebar: Settings (9) -->
          <Panel x:Name="Sidebar9" IsVisible="False">
            <TextBlock Text="{loc:Str Nav_Settings}" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       Margin="20,12,16,0" />
          </Panel>
        </Panel>

      </DockPanel>
    </Border>

    <!-- ═══ Main Content ═══ -->
    <Grid Grid.Column="1">

      <!-- Onboarding overlay -->
      <views:OnboardingView x:Name="OnboardingPanel" DataContext="{Binding OnboardingVM}"
                            ZIndex="100" />

      <!-- Dashboard (index 0) -->
      <ScrollViewer x:Name="Page0" DataContext="{Binding ShiftsVM}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" Spacing="18">
          <DockPanel>
            <Button DockPanel.Dock="Right" Classes="subtle"
                    Padding="14,7" MinHeight="0"
                    IsEnabled="{Binding !IsRefreshing}"
                    Command="{Binding RefreshTrackedItemsCommand}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="↻" IsVisible="{Binding !IsRefreshing}" />
                <TextBlock Text="{loc:Str Dashboard_RefreshNow}" IsVisible="{Binding !IsRefreshing}" />
                <TextBlock Text="Refreshing…" IsVisible="{Binding IsRefreshing}"
                           Foreground="{DynamicResource Brush.TextTertiary}" />
              </StackPanel>
            </Button>
            <StackPanel Spacing="2">
              <TextBlock Text="{loc:Str Dashboard_Title}" FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource Brush.TextPrimary}" />
              <TextBlock Text="{Binding ActiveShift.Name}"
                         FontSize="13"
                         Foreground="{DynamicResource Brush.TextSecondary}"
                         IsVisible="{Binding HasActiveShift}" />
            </StackPanel>
          </DockPanel>

          <!-- Indeterminate progress bar — visible only while fetching from ADO -->
          <ProgressBar IsIndeterminate="True" Height="3" CornerRadius="2"
                       IsVisible="{Binding IsRefreshing}"
                       Margin="0,-8,0,0" />

          <UniformGrid Columns="5" Rows="1">
            <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Text="{loc:Str Dashboard_Stats_Total}" FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding TotalTrackedCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" />
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Text="{loc:Str Dashboard_Stats_InProgress}" FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding InProgressCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" />
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Text="{loc:Str Dashboard_Stats_NeedsAction}" FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding NeedsActionCount}" FontSize="24" FontWeight="Bold" Foreground="#D97706" />
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Text="{loc:Str Dashboard_Completed}" FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding CompletedCount}" FontSize="24" FontWeight="Bold" Foreground="#16A34A" />
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="10" Padding="14">
              <StackPanel>
                <TextBlock Text="{loc:Str Dashboard_Failed}" FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding FailedCount}" FontSize="24" FontWeight="Bold" Foreground="#DC2626" />
              </StackPanel>
            </Border>
          </UniformGrid>

          <Grid ColumnDefinitions="2*,16,*">
            <StackPanel Grid.Column="0" Spacing="10">
              <TextBlock Text="Tracked runs" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.TextPrimary}" />
              <StackPanel IsVisible="{Binding !HasActiveTrackedItems}"
                          HorizontalAlignment="Center" Margin="0,48,0,0" Spacing="8">
                <TextBlock Text="📭" FontSize="32" HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Str Dashboard_NoItems}"
                           Foreground="{DynamicResource Brush.TextSecondary}" />
              </StackPanel>
              <ItemsControl ItemsSource="{Binding ActiveTrackedItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:TrackedItemDisplay">
                    <Button Padding="0" Margin="0,0,0,8"
                            HorizontalContentAlignment="Stretch"
                            Classes="run-card"
                            IsEnabled="{Binding HasAdoLink}"
                            Command="{Binding $parent[ItemsControl].((vm:ShiftsViewModel)DataContext).OpenTrackedItemCommand}"
                            CommandParameter="{Binding}">
                      <Border Background="{DynamicResource Brush.Surface}"
                              BorderBrush="{DynamicResource Brush.Border}"
                              BorderThickness="1" CornerRadius="10"
                              Padding="14,12">
                        <StackPanel Spacing="5">
                          <DockPanel>
                            <Border DockPanel.Dock="Right"
                                    Classes="run-status"
                                    Classes.succeeded="{Binding IsSucceeded}"
                                    Classes.failed="{Binding IsFailed}"
                                    Classes.in-progress="{Binding IsInProgress}"
                                    CornerRadius="4" Padding="7,2">
                              <TextBlock Text="{Binding Item.Status}" FontSize="11" />
                            </Border>
                            <StackPanel>
                              <TextBlock Text="{Binding PipelineName}" FontSize="14" FontWeight="SemiBold"
                                         Foreground="{DynamicResource Brush.TextPrimary}" />
                              <TextBlock Text="{Binding BuildLabel}" FontSize="12"
                                         Foreground="{DynamicResource Brush.TextSecondary}" />
                            </StackPanel>
                          </DockPanel>
                          <TextBlock Text="{Binding StepSummary}" FontSize="12"
                                     Foreground="{DynamicResource Brush.TextSecondary}" />
                          <TextBlock Text="{Binding NextStep}" FontSize="12"
                                     Foreground="{DynamicResource Brush.TextTertiary}"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Item.ActionReason}" FontSize="12"
                                     Foreground="#D97706" TextWrapping="Wrap"
                                     IsVisible="{Binding Item.ActionReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                          <TextBlock Text="Open in ADO ↗" FontSize="11"
                                     Foreground="{DynamicResource Brush.Accent}"
                                     IsVisible="{Binding HasAdoLink}"
                                     HorizontalAlignment="Right" Margin="0,2,0,0" />
                        </StackPanel>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="10">
              <TextBlock Text="Notifications &amp; actions" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.TextPrimary}" />
              <TextBlock Text="No shift events yet."
                         IsVisible="{Binding !HasRecentEvents}"
                         Foreground="{DynamicResource Brush.TextTertiary}" />
              <ItemsControl ItemsSource="{Binding RecentEvents}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:ShiftEvent">
                    <Border Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="10,8" Margin="0,0,0,6">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Message}"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MMM d, HH:mm}'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Brush.TextTertiary}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>

      <!-- Shift Management (index 1) -->
      <Panel x:Name="Page1" IsVisible="False">
        <views:ShiftsView DataContext="{Binding ShiftsVM}" />
      </Panel>

      <!-- Chat (index 2) -->
      <Panel x:Name="Page2" IsVisible="False">
        <views:ChatView DataContext="{Binding ChatVM}" />
      </Panel>

      <!-- Service Projects (index 3) — detail/editor only (list is in sidebar) -->
      <Panel x:Name="Page3" IsVisible="False">
        <views:ServiceProjectsView DataContext="{Binding ServiceProjectsVM}" />
      </Panel>

      <!-- Memories (index 4) -->
      <Panel x:Name="Page4" IsVisible="False">
        <views:MemoriesView DataContext="{Binding MemoriesVM}" />
      </Panel>

      <!-- Skills (index 5) -->
      <Panel x:Name="Page5" IsVisible="False">
        <views:CapabilitiesView DataContext="{Binding SkillsVM}" />
      </Panel>

      <!-- MCP Servers (index 6) -->
      <Panel x:Name="Page6" IsVisible="False">
        <views:CapabilitiesView DataContext="{Binding McpServersVM}" />
      </Panel>

      <!-- Tools (index 7) -->
      <Panel x:Name="Page7" IsVisible="False">
        <views:CapabilitiesView DataContext="{Binding ToolsVM}" />
      </Panel>

      <!-- Agents (index 8) -->
      <Panel x:Name="Page8" IsVisible="False">
        <views:CapabilitiesView DataContext="{Binding AgentsVM}" />
      </Panel>

      <!-- Settings (index 9) -->
      <Panel x:Name="Page9" IsVisible="False">
        <views:SettingsView DataContext="{Binding SettingsVM}" />
      </Panel>

    </Grid>
  </Grid>

  <Window.Styles>
    <!-- Clickable run card button (transparent, no chrome) -->
    <Style Selector="Button.run-card">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.run-card /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.run-card:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.run-card:pointerover Border">
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
    </Style>
    <Style Selector="Button.run-card:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>
    <Style Selector="Button.run-card:disabled">
      <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <!-- Status badge colors -->
    <Style Selector="Border.run-status">
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceVariant}" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="Border.run-status TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    </Style>
    <Style Selector="Border.run-status.succeeded">
      <Setter Property="Background" Value="#DCFCE7" />
    </Style>
    <Style Selector="Border.run-status.succeeded TextBlock">
      <Setter Property="Foreground" Value="#15803D" />
    </Style>
    <Style Selector="Border.run-status.failed">
      <Setter Property="Background" Value="#FEE2E2" />
    </Style>
    <Style Selector="Border.run-status.failed TextBlock">
      <Setter Property="Foreground" Value="#B91C1C" />
    </Style>
    <Style Selector="Border.run-status.in-progress">
      <Setter Property="Background" Value="#DBEAFE" />
    </Style>
    <Style Selector="Border.run-status.in-progress TextBlock">
      <Setter Property="Foreground" Value="#1D4ED8" />
    </Style>

    <!-- Nav pill — horizontal bar at bottom of sidebar -->
    <Style Selector="Border.nav-pill">
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="5" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 1 6 0 #16000000" />
      <Setter Property="Transitions">
        <Transitions>
          <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.25" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.nav-pill:pointerover">
      <Setter Property="BoxShadow" Value="0 4 16 0 #28000000" />
    </Style>

    <!-- Nav icon buttons inside pill -->
    <Style Selector="Button.nav-icon">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Margin" Value="1" />
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="28" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.nav-icon:pointerover">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface2}" />
    </Style>
    <Style Selector="Button.nav-icon:pressed">
      <Setter Property="Opacity" Value="0.7" />
    </Style>
    <Style Selector="Button.nav-icon.active">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface2}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>
  </Window.Styles>

</Window>
