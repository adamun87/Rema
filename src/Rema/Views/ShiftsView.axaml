<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Rema.ViewModels"
             xmlns:models="using:Rema.Models"
             xmlns:loc="using:Rema.Localization"
             x:Class="Rema.Views.ShiftsView"
             x:DataType="vm:ShiftsViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.section-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextTertiary}" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="Border.status-badge">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="6,2" />
    </Style>
  </UserControl.Styles>

  <Panel>

    <!-- ═══ No active shift: Start shift form ═══ -->
    <ScrollViewer IsVisible="{Binding !HasActiveShift}"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="20" Margin="32,40,32,32" MaxWidth="560" HorizontalAlignment="Center">

        <!-- Icon + headline -->
        <StackPanel HorizontalAlignment="Center" Spacing="8">
          <TextBlock Text="🕐" FontSize="40" HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Str Shift_Title}"
                     FontSize="22" FontWeight="Bold"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource Brush.TextPrimary}" />
          <TextBlock Text="{loc:Str Shift_NoActiveShift}"
                     FontSize="14" HorizontalAlignment="Center"
                     Foreground="{DynamicResource Brush.TextSecondary}" />
        </StackPanel>

        <!-- Start shift card -->
        <Border Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="12" Padding="24">
          <StackPanel Spacing="14">
            <TextBlock Classes="field-label" Text="{loc:Str Shift_ShiftName}" />
            <TextBox Text="{Binding NewShiftName, Mode=TwoWay}"
                     Watermark="{loc:Str Shift_ShiftNameWatermark}" />
            <Button Classes="accent"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="0,10"
                    Command="{Binding StartShiftCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="▶" />
                <TextBlock Text="{loc:Str Shift_StartShift}" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <!-- Shift history section -->
        <StackPanel Spacing="8" IsVisible="{Binding HasShiftHistory}">
          <TextBlock Classes="section-label" Text="{loc:Str Shift_History}" />
          <ItemsControl ItemsSource="{Binding ShiftHistory}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Shift">
                <Border Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource Brush.TextPrimary}" />
                    <TextBlock FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}">
                      <Run Text="{loc:Str Shift_StartedAt}" />
                      <Run Text="{Binding StartedAt, StringFormat='{}{0:MMM d, HH:mm}'}" />
                    </TextBlock>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

    <!-- ═══ Active shift: tracked items dashboard ═══ -->
    <DockPanel IsVisible="{Binding HasActiveShift}">

      <!-- Active shift header -->
      <Border DockPanel.Dock="Top"
              Background="{DynamicResource Brush.Surface}"
              BorderBrush="{DynamicResource Brush.Border}"
              BorderThickness="0,0,0,1"
              Padding="24,14">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Classes="subtle"
                  Padding="14,7" MinHeight="0"
                  Command="{Binding EndShiftCommand}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="⏹" />
              <TextBlock Text="{loc:Str Shift_EndShift}" />
            </StackPanel>
          </Button>
          <StackPanel VerticalAlignment="Center" Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="▶" Foreground="{DynamicResource Brush.Accent}" FontSize="13" VerticalAlignment="Center" />
              <TextBlock Text="{Binding ActiveShift.Name}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.TextPrimary}" />
            </StackPanel>
            <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextTertiary}">
              <Run Text="{loc:Str Shift_StartedAt}" />
              <Run Text="{Binding ActiveShift.StartedAt, StringFormat='{}{0:MMM d, HH:mm}'}" />
            </TextBlock>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Add tracked item form -->
      <Border DockPanel.Dock="Bottom"
              IsVisible="{Binding IsAddingTrackedItem}"
              Background="{DynamicResource Brush.Surface}"
              BorderBrush="{DynamicResource Brush.Border}"
              BorderThickness="0,1,0,0"
              Padding="24,16">
        <StackPanel Spacing="12" MaxWidth="560">
          <TextBlock Classes="section-label" Text="{loc:Str Shift_TrackPipeline}" />
          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Classes="field-label" Text="{loc:Str Shift_ServiceProject}" />
              <ComboBox ItemsSource="{Binding ServiceProjects}"
                        SelectedItem="{Binding SelectedServiceProject, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        DisplayMemberBinding="{Binding Name}" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Classes="field-label" Text="{loc:Str Shift_Pipeline}" />
              <ComboBox ItemsSource="{Binding AvailablePipelines}"
                        SelectedItem="{Binding SelectedPipelineConfig, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        DisplayMemberBinding="{Binding DisplayName}" />
            </StackPanel>
          </Grid>
          <StackPanel Spacing="4">
            <TextBlock Classes="field-label" Text="{loc:Str Shift_Notes}" />
            <TextBox Text="{Binding TrackedItemNotes, Mode=TwoWay}"
                     Watermark="Optional context…" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Classes="subtle" Content="{loc:Str Shift_CancelAdd}"
                    Command="{Binding CancelAddTrackedItemCommand}" />
            <Button Classes="accent" Content="{loc:Str Shift_AddItem}"
                    Command="{Binding AddTrackedItemCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Toolbar: Track Pipeline button -->
      <DockPanel DockPanel.Dock="Bottom"
                 IsVisible="{Binding !IsAddingTrackedItem}"
                 Margin="24,8">
        <Button Classes="subtle"
                HorizontalAlignment="Left"
                Command="{Binding ShowAddTrackedItemCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="+" FontWeight="Bold" />
            <TextBlock Text="{loc:Str Shift_TrackPipeline}" />
          </StackPanel>
        </Button>
      </DockPanel>

      <!-- Tracked items list -->
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <Panel>

          <!-- Empty state -->
          <StackPanel IsVisible="{Binding !HasActiveTrackedItems}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <TextBlock Text="📭" FontSize="32" HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Str Shift_NoTracked}"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
          </StackPanel>

          <!-- Items -->
          <ItemsControl ItemsSource="{Binding ActiveTrackedItems}" Margin="16,12">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:TrackedItemDisplay">
                <Border Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="16,12" Margin="0,0,0,8">
                  <DockPanel>
                    <!-- Right actions -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                      <Button Classes="subtle" Content="🔔" Padding="6,4" MinHeight="0"
                              ToolTip.Tip="{loc:Str Shift_RequiresAction}"
                              Command="{Binding $parent[ItemsControl].((vm:ShiftsViewModel)DataContext).MarkRequiresActionCommand}"
                              CommandParameter="{Binding}" />
                      <Button Classes="subtle" Content="✕" Padding="6,4" MinHeight="0"
                              ToolTip.Tip="{loc:Str Shift_RemoveFromShift}"
                              Command="{Binding $parent[ItemsControl].((vm:ShiftsViewModel)DataContext).RemoveTrackedItemCommand}"
                              CommandParameter="{Binding}" />
                    </StackPanel>

                    <!-- Left content -->
                    <StackPanel Spacing="6">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding PipelineName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextPrimary}" />
                        <Border Classes="status-badge"
                                Background="#FFF3CD"
                                IsVisible="{Binding Item.RequiresAction}">
                          <TextBlock Text="{loc:Str Shift_RequiresAction}"
                                     FontSize="11" FontWeight="Medium"
                                     Foreground="#856404" />
                        </Border>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding ProjectName}"
                                   FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" />
                        <TextBlock Text="·" Foreground="{DynamicResource Brush.TextTertiary}" FontSize="12" />
                        <Border Classes="status-badge"
                                Background="{DynamicResource Brush.SurfaceVariant}">
                          <TextBlock Text="{Binding Item.Status}"
                                     FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" />
                        </Border>
                        <TextBlock Text="{Binding Item.CurrentStage}"
                                   FontSize="12" Foreground="{DynamicResource Brush.TextTertiary}"
                                   IsVisible="{Binding Item.CurrentStage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                      </StackPanel>
                      <TextBlock Text="{Binding Item.ActionReason}"
                                 FontSize="12" Foreground="#856404"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding Item.ActionReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Panel>
      </ScrollViewer>

    </DockPanel>
  </Panel>

</UserControl>